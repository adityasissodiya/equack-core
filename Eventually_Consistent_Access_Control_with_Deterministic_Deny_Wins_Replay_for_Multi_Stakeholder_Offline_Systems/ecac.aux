\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Enforcement stack comparison: \textsc  {EQuack}{} vs.\ p2panda. Both systems build on signed append-only logs with causal DAG ordering and gossip replication. The critical difference is where deny-wins enforcement runs: in \textsc  {EQuack}{}, the Gate function is a mandatory protocol-level step during deterministic replay; in p2panda, the access-control CRDT computes the invalidation set, but retroactive removal of application data is an application-layer choice.}}{6}{figure.35}\protected@file@percent }
\newlabel{fig:enforcement-compare-paperC}{{1}{6}{Enforcement stack comparison: \equack {} vs.\ p2panda. Both systems build on signed append-only logs with causal DAG ordering and gossip replication. The critical difference is where deny-wins enforcement runs: in \equack {}, the Gate function is a mandatory protocol-level step during deterministic replay; in p2panda, the access-control CRDT computes the invalidation set, but retroactive removal of application data is an application-layer choice}{figure.35}{}}
\newlabel{fig:enforcement-compare-paperC@cref}{{[figure][1][]1}{[1][5][]6}}
