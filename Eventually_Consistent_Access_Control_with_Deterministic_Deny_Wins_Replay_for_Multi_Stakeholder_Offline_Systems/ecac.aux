\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Semantic replay pipeline of \textsc  {EQuack}{}. Replicas ingest the same signed events, construct the same activated causal DAG, derive the same TrustView and authorization epochs, make the same deny-wins apply/skip decisions, and therefore materialize the same CRDT state digest. Anti-entropy, persistence, and audit are support paths rather than independent semantics.}}{7}{figure.38}\protected@file@percent }
\newlabel{fig:ecac-overview-paperC}{{2}{7}{Semantic replay pipeline of \equack {}. Replicas ingest the same signed events, construct the same activated causal DAG, derive the same TrustView and authorization epochs, make the same deny-wins apply/skip decisions, and therefore materialize the same CRDT state digest. Anti-entropy, persistence, and audit are support paths rather than independent semantics}{figure.38}{}}
