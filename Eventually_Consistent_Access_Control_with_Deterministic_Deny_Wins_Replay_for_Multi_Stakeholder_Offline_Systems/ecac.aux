\citation{DEEPA2022209}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Partition-heal semantics of deterministic deny-wins replay. Replicas share a common prefix before partition. During the partition, replica~A receives \texttt  {Revoke(U)} while replica~B, still missing that event, locally accepts subsequent writes by $U$ under stale evidence. After anti-entropy, all replicas replay the union log in the same deterministic order; the revoke closes $U$'s epoch, the post-revoke writes are skipped, and every replica converges to the same final state digest.}}{12}{figure.62}\protected@file@percent }
\newlabel{fig:partition-heal-paperC}{{4}{12}{Partition-heal semantics of deterministic deny-wins replay. Replicas share a common prefix before partition. During the partition, replica~A receives \texttt {Revoke(U)} while replica~B, still missing that event, locally accepts subsequent writes by $U$ under stale evidence. After anti-entropy, all replicas replay the union log in the same deterministic order; the revoke closes $U$'s epoch, the post-revoke writes are skipped, and every replica converges to the same final state digest}{figure.62}{}}
\newlabel{fig:partition-heal-paperC@cref}{{[figure][4][]4}{[1][11][]12}}
