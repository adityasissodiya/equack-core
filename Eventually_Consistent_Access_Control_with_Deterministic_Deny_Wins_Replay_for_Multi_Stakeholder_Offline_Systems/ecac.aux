\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Operation structure and causal DAG\spacefactor \@m {}. Each node shows the OpHeader fields, typed payload, and Ed25519 signature. Edges encode three semantic relationships: trust-chain links (dashed teal) connect issuer keys to credentials, authorization links (dotted blue) connect credentials to grants and grants to gated data operations, and data/causal links (solid orange) encode CRDT merge points and ordering dependencies. Circled numbers indicate the deterministic replay order from Algorithm~\ref {alg:linearize-paperC}.}}{8}{figure.41}\protected@file@percent }
\newlabel{fig:dag-structure-paperC}{{3}{8}{Operation structure and causal DAG\@. Each node shows the OpHeader fields, typed payload, and Ed25519 signature. Edges encode three semantic relationships: trust-chain links (dashed teal) connect issuer keys to credentials, authorization links (dotted blue) connect credentials to grants and grants to gated data operations, and data/causal links (solid orange) encode CRDT merge points and ordering dependencies. Circled numbers indicate the deterministic replay order from Algorithm~\ref {alg:linearize-paperC}}{figure.41}{}}
\newlabel{fig:dag-structure-paperC@cref}{{[figure][3][]3}{[1][5][]8}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Authorization epoch lifecycle. A \texttt  {GRANT} referencing a valid credential opens an epoch at its replay position; a \texttt  {REVOKE} closes the epoch. DATA operations inside an active epoch pass the deny-wins Gate (\textbf  {APPLY}); those outside any epoch are skipped (\textbf  {SKIP}). Revocation is not irreversible: a subsequent \texttt  {GRANT} (re-grant) opens a fresh epoch, restoring access for later positions in the replay order.}}{8}{figure.46}\protected@file@percent }
\newlabel{fig:epoch-lifecycle-paperC}{{4}{8}{Authorization epoch lifecycle. A \texttt {GRANT} referencing a valid credential opens an epoch at its replay position; a \texttt {REVOKE} closes the epoch. DATA operations inside an active epoch pass the deny-wins Gate (\textbf {APPLY}); those outside any epoch are skipped (\textbf {SKIP}). Revocation is not irreversible: a subsequent \texttt {GRANT} (re-grant) opens a fresh epoch, restoring access for later positions in the replay order}{figure.46}{}}
\newlabel{fig:epoch-lifecycle-paperC@cref}{{[figure][4][]4}{[1][6][]8}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Two-writer replay example under deterministic deny-wins semantics. An in-band \texttt  {IssuerKey} seeds TrustView; verified \texttt  {Credential}+\texttt  {Grant} pairs open epochs for writers A and B; reconciliation yields one shared event set; and \texttt  {Revoke(B)} closes only B's epoch in the deterministic replay order. Every replica therefore applies both writers' pre-revoke data, skips B's post-revoke data, continues applying A's post-revoke data, and emits the same audit outcomes.}}{9}{figure.51}\protected@file@percent }
\newlabel{fig:deny-wins-paperC}{{5}{9}{Two-writer replay example under deterministic deny-wins semantics. An in-band \texttt {IssuerKey} seeds TrustView; verified \texttt {Credential}+\texttt {Grant} pairs open epochs for writers A and B; reconciliation yields one shared event set; and \texttt {Revoke(B)} closes only B's epoch in the deterministic replay order. Every replica therefore applies both writers' pre-revoke data, skips B's post-revoke data, continues applying A's post-revoke data, and emits the same audit outcomes}{figure.51}{}}
\newlabel{fig:deny-wins-paperC@cref}{{[figure][5][]5}{[1][7][]9}}
