\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Deterministic replay slice from the compliance fixture. An in-band \texttt  {IssuerKey} seeds TrustView, verified \texttt  {Credential}+\texttt  {Grant} pairs open epochs for writers A and B, and \texttt  {Revoke(B)} closes only B's epoch. The deny-wins gate therefore applies both writers' pre-revoke data, skips B's post-revoke data, continues applying A's post-revoke data, and emits matching audit events.}}{8}{figure.43}\protected@file@percent }
\newlabel{fig:deny-wins-paperC}{{3}{8}{Deterministic replay slice from the compliance fixture. An in-band \texttt {IssuerKey} seeds TrustView, verified \texttt {Credential}+\texttt {Grant} pairs open epochs for writers A and B, and \texttt {Revoke(B)} closes only B's epoch. The deny-wins gate therefore applies both writers' pre-revoke data, skips B's post-revoke data, continues applying A's post-revoke data, and emits matching audit events}{figure.43}{}}
\newlabel{fig:deny-wins-paperC@cref}{{[figure][3][]3}{[1][6][]8}}
